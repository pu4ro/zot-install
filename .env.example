# ============================================================================
# Zot Registry Configuration
# Copy this file to .env and modify as needed:
#   cp .env.example .env
# ============================================================================

# ── Registry Settings ───────────────────────────────────────────────────────
ZOT_DOMAIN=cr.makina.rocks
ZOT_IP=                          # Required: Server IP (e.g., 192.168.135.121)
ZOT_PORT=443                     # Host port to expose
ZOT_INTERNAL_PORT=5000           # Container internal port

# ── Storage & Paths ─────────────────────────────────────────────────────────
DATA_DIR=/data                   # Base data directory
# CERT_DIR=/data/cert            # TLS cert directory (default: ${DATA_DIR}/cert)
# ZOT_STORAGE=/data/zot          # Registry storage   (default: ${DATA_DIR}/zot)

# ── Container Image ─────────────────────────────────────────────────────────
ZOT_IMAGE=ghcr.io/project-zot/zot:latest

# ── Air-Gapped Mode ─────────────────────────────────────────────────────────
AIRGAP=false                     # Set to true for air-gapped environments
ZOT_IMAGE_TAR=                   # Path to zot image tar (required if AIRGAP=true)
                                 # Generate with: make save-image

# ── Install Options ─────────────────────────────────────────────────────────
SKIP_HOSTS=false                 # Skip /etc/hosts modification
SKIP_CERTS=false                 # Skip TLS cert generation (use existing certs)
FORCE=false                      # Overwrite existing installation

# ── Migration Settings ──────────────────────────────────────────────────────
SOURCE_REGISTRY=cr.makina.rocks
DEST_REGISTRY=                   # Destination registry for migration
STRATEGY=skopeo                  # Migration strategy: skopeo, zot-sync, filesystem, oras
SOURCE_STORAGE=/data/zot         # Source OCI storage directory
DEST_STORAGE=                    # Destination storage (for filesystem strategy)
SOURCE_CA=/data/cert/ca.crt      # Source registry CA cert
DEST_CA=                         # Destination registry CA cert
NAMESPACE=zot-registry           # K8s namespace for zot deployment
